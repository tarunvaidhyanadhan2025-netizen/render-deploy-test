# ── Core ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── OCR ────────────────────────────────────────────────────────────────────────
OCR_PROVIDER=tesseract

# ── LLM Provider ───────────────────────────────────────────────────────────────
# Single provider:
#   MODEL_PROVIDER=gemini
#   MODEL_NAME=gemini-2.0-flash-lite
#   GEMINI_API_KEY=your_key_here
#
# Fallback chain (tries each in order on quota/error):
#   MODEL_PROVIDER=fallback
#   FALLBACK_CHAIN=gemini:gemini-2.0-flash-lite,gemini:gemini-2.5-flash,openai:gpt-4o-mini
#   GEMINI_API_KEY=your_gemini_key
#   OPENAI_API_KEY=your_openai_key

MODEL_PROVIDER=gemini
MODEL_NAME=gemini-2.0-flash-lite
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=2048

# ── API Keys ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Fallback chain (only used when MODEL_PROVIDER=fallback) ───────────────────
FALLBACK_CHAIN=gemini:gemini-2.0-flash-lite,gemini:gemini-2.5-flash,openai:gpt-4o-mini

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prescription_db

# ── Upload ─────────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
